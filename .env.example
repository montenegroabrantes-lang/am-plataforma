# ─────────────────────────────────────────────
#  AM Advogados — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# ─────────────────────────────────────────────

# ── BANCO DE DADOS ───────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/am_plataforma
REDIS_URL=redis://localhost:6379

# ── AUTENTICAÇÃO JWT ─────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_secreta_longa
JWT_REFRESH_SECRET=troque_por_outra_chave_diferente

# ── CRIPTOGRAFIA AES-256 ─────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64_caracteres_hex_aqui

# ── MASTER 01 — usado apenas no seed inicial ─
MASTER_NOME=Ramona
MASTER_EMAIL=seu@email.com
MASTER_SENHA=senha_forte_aqui

# ── IA — ANTHROPIC (CLAUDE) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HABILITADO=true

# ── IA — OPENAI ──────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_TEXTO=gpt-4o
OPENAI_HABILITADO=true

# ── ROTEAMENTO DE TAREFAS DE IA ──────────────
AI_TAREFA_DIAGNOSTICO=claude
AI_TAREFA_PETICAO=claude

# ── GOOGLE DRIVE ─────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
GOOGLE_DRIVE_PASTA_RAIZ=ID_DA_PASTA_RAIZ_NO_DRIVE

# ── DIGISAC / WHATSAPP ───────────────────────
DIGISAC_API_URL=https://api.digisac.com.br
DIGISAC_TOKEN=...
DIGISAC_NUMERO_ESCRITORIO=5583999999999

# ── PJe ──────────────────────────────────────
PJE_TJPB_URL=https://pje.tjpb.jus.br/pje/login.seam
PJE_TJRN_URL=https://pje.tjrn.jus.br/pje/login.seam
PJE_TJPE_URL=https://pje.tjpe.jus.br/pje/login.seam
PJE_TRF1_URL=https://pje.trf1.jus.br/pje/login.seam

# ── eProc ────────────────────────────────────
EPROC_TRF5_URL=https://eproc.trf5.jus.br/eproc/login.php
EPROC_TRF3_URL=https://eproc.trf3.jus.br/eproc/login.php
EPROC_TRF4_URL=https://eproc.trf4.jus.br/eproc/login.php
EPROC_TRF6_URL=https://eproc.trf6.jus.br/eproc/login.php

# ── PUPPETEER ────────────────────────────────
# Railway: /usr/bin/chromium  |  Local: deixe vazio
CHROMIUM_PATH=

# ── BACKUP ───────────────────────────────────
BACKUP_DIR=/tmp/am-backups

# ── SERVIDOR ─────────────────────────────────
PORT=3001
NODE_ENV=development
